---
import Layout from "../layouts/Layout.astro";
import { generateOrganizationSchema } from "../lib/schema";

const schema = generateOrganizationSchema();
---

<Layout
  title="Shop - The White Rabbit Society"
  description="Cop the merch, support White Rabbit. WCS apparel and gear coming soon."
  schema={schema}
>
  <main class="shop-page">
    <div class="container">
      <header class="page-header">
        <h1 class="page-title gradient-text">The Shop</h1>
        <p class="page-subtitle">Cop the Merch · Support White Rabbit</p>
      </header>

      <div class="coming-soon-block">
        <div class="terminal-line">$ loading shop...</div>
        <div class="terminal-line blink">_ </div>
        <p class="coming-soon-text">Merch drop incoming.</p>
        <p class="coming-soon-sub">
          T-shirts, stickers, and gear for the Arizona WCS scene. Stay tuned.
        </p>
      </div>
    </div>
  </main>
</Layout>

<style>
  .shop-page {
    padding: 3rem 0;
    min-height: calc(100vh - 80px);
    display: flex;
    flex-direction: column;
  }

  .page-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .page-title {
    font-size: clamp(2.5rem, 8vw, 4rem);
    margin-bottom: 0.5rem;
    letter-spacing: 0.1em;
  }

  .page-subtitle {
    font-size: 1rem;
    color: var(--text-secondary);
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .coming-soon-block {
    max-width: 480px;
    margin: 0 auto;
    text-align: center;
    padding: 48px 32px;
    border: 1px solid var(--border-color);
    background: var(--bg-secondary);
  }

  .terminal-line {
    font-family: var(--font-primary);
    color: var(--accent-primary);
    font-size: 1.1rem;
    margin-bottom: 6px;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .blink {
    animation: blink 1s step-start infinite;
    margin-bottom: 32px;
  }

  .coming-soon-text {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 12px;
  }

  .coming-soon-sub {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin: 0;
  }
</style>
