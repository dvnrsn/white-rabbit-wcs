---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Order Cancelled - White Rabbit Shop" description="Your order was cancelled.">
  <main class="result-page">
    <div class="container">
      <div class="result-block">
        <div class="result-icon">✕</div>
        <h1 class="result-title">Cancelled</h1>
        <p class="result-text">No charge was made. Head back and try again whenever you're ready.</p>
        <a href="/shop" class="btn">Back to Shop</a>
      </div>
    </div>
  </main>
</Layout>

<style>
  .result-page {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6rem 0;
  }

  .result-block {
    text-align: center;
    max-width: 480px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .result-icon {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    border: 2px solid var(--border-color);
    color: var(--text-muted);
    font-size: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .result-title {
    font-size: 2.5rem;
    letter-spacing: 0.1em;
    margin: 0;
    color: var(--text-secondary);
  }

  .result-text {
    color: var(--text-muted);
    line-height: 1.7;
    margin: 0;
    font-family: var(--font-secondary);
  }
</style>
