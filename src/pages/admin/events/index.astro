---
export const prerender = false;

import "../../../styles/themes.css";

// Auth guard
const session = Astro.cookies.get("admin_session");
if (!session?.value) {
  return Astro.redirect("/admin/login");
}

const db = Astro.locals.runtime?.env?.DB;

interface EventRow {
  id: string;
  title: string;
  date: string;
  start_time: string | null;
  type: string | null;
  is_recurring: number;
  organizer_name: string | null;
  venue_name: string | null;
}

let events: EventRow[] = [];
let dbError = "";

if (db) {
  try {
    const { results } = await db
      .prepare(
        `SELECT e.id, e.title, e.date, e.start_time, e.type, e.is_recurring,
                o.name AS organizer_name, v.name AS venue_name
         FROM events e
         LEFT JOIN organizers o ON e.organizer_id = o.id
         LEFT JOIN venues v ON e.venue_id = v.id
         ORDER BY e.date DESC
         LIMIT 100`
      )
      .all<EventRow>();
    events = results;
  } catch (e) {
    dbError = e instanceof Error ? e.message : String(e);
  }
} else {
  dbError = "Database not available";
}
---

<!doctype html>
<html lang="en" data-theme="white-rabbit">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Events — Admin — White Rabbit</title>
    <script is:inline>
      const savedTheme = localStorage.getItem("white-rabbit-theme") || "white-rabbit";
      document.documentElement.setAttribute("data-theme", savedTheme);
    </script>
  </head>
  <body>
    <div class="container">
      <header>
        <div class="breadcrumb">
          <a href="/admin">Admin</a>
          <span class="sep">/</span>
          <span>Events</span>
        </div>
        <a href="/admin/events/new" class="btn-new">+ New Event</a>
      </header>

      {dbError && <p class="db-error">Database error: {dbError}</p>}

      {
        events.length === 0 && !dbError ? (
          <p class="empty">No events yet. <a href="/admin/events/new">Create the first one.</a></p>
        ) : (
          <table>
            <thead>
              <tr>
                <th>Date</th>
                <th>Title</th>
                <th>Type</th>
                <th>Organizer</th>
                <th>Venue</th>
                <th>Recurring</th>
              </tr>
            </thead>
            <tbody>
              {events.map((ev) => (
                <tr>
                  <td class="date">{ev.date}{ev.start_time ? ` ${ev.start_time}` : ""}</td>
                  <td class="title">{ev.title}</td>
                  <td><span class={`badge badge-${ev.type ?? "social"}`}>{ev.type ?? "social"}</span></td>
                  <td>{ev.organizer_name ?? "—"}</td>
                  <td>{ev.venue_name ?? "—"}</td>
                  <td>{ev.is_recurring ? "Yes" : "No"}</td>
                </tr>
              ))}
            </tbody>
          </table>
        )
      }
    </div>
  </body>
</html>

<style>
  body {
    margin: 0;
    background: var(--bg-primary);
    color: var(--text-primary);
    font-family: var(--font-primary);
    min-height: 100vh;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 40px 32px;
  }

  header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 32px;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.9rem;
  }

  .breadcrumb a {
    color: var(--accent-primary);
    text-decoration: none;
  }

  .sep {
    color: var(--text-muted);
  }

  .btn-new {
    background: transparent;
    border: 2px solid var(--accent-primary);
    color: var(--text-primary);
    padding: 8px 18px;
    text-decoration: none;
    font-family: var(--font-primary);
    font-size: 0.9rem;
    transition: all 0.2s;
  }

  .btn-new:hover {
    background: var(--accent-primary);
    color: var(--bg-primary);
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }

  th {
    text-align: left;
    padding: 10px 14px;
    border-bottom: 2px solid var(--border-color);
    color: var(--text-secondary);
    font-weight: normal;
  }

  td {
    padding: 10px 14px;
    border-bottom: 1px solid var(--border-color);
    vertical-align: middle;
  }

  tr:hover td {
    background: var(--bg-secondary);
  }

  .date {
    white-space: nowrap;
    color: var(--text-secondary);
    font-size: 0.85rem;
  }

  .title {
    font-weight: bold;
  }

  .badge {
    display: inline-block;
    padding: 2px 8px;
    border: 1px solid var(--border-color);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .badge-social {
    border-color: var(--accent-primary);
    color: var(--accent-primary);
  }

  .badge-workshop {
    border-color: #ffaa00;
    color: #ffaa00;
  }

  .badge-competition {
    border-color: #ff4488;
    color: #ff4488;
  }

  .empty {
    color: var(--text-secondary);
  }

  .db-error {
    color: #ff4444;
    border: 1px solid #ff4444;
    padding: 12px 16px;
  }
</style>
