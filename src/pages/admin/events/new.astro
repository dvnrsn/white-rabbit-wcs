---
export const prerender = false;

import "../../../styles/themes.css";
import { getDb } from "../../../lib/db";
import { events as eventsTable, organizers as organizersTable, venues as venuesTable } from "../../../lib/db/schema";
import { asc } from "drizzle-orm";

// Auth guard
const session = Astro.cookies.get("admin_session");
if (!session?.value) {
  return Astro.redirect("/admin/login");
}

const env = Astro.locals.runtime?.env;

let organizers: { id: string; name: string }[] = [];
let venues: { id: string; name: string; city: string | null }[] = [];

if (env?.DB) {
  const db = getDb(env);
  const [orgRows, venueRows] = await Promise.all([
    db.select({ id: organizersTable.id, name: organizersTable.name })
      .from(organizersTable)
      .orderBy(asc(organizersTable.name)),
    db.select({ id: venuesTable.id, name: venuesTable.name, city: venuesTable.city })
      .from(venuesTable)
      .orderBy(asc(venuesTable.name)),
  ]);
  organizers = orgRows;
  venues = venueRows;
}

let formError = "";

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const body = Object.fromEntries([...formData.entries()].map(([k, v]) => [k, String(v)]));

  const recurringMap: Record<string, string | null> = {
    once: null,
    weekly: "FREQ=WEEKLY",
    biweekly: "FREQ=WEEKLY;INTERVAL=2",
    monthly: "FREQ=MONTHLY",
  };

  const rrule = recurringMap[body.recurring ?? "once"] ?? null;
  const isRecurring = rrule ? 1 : 0;

  if (!body.title || !body.date) {
    formError = "Title and date are required.";
  } else if (!env?.DB) {
    formError = "Database not available.";
  } else {
    try {
      const db = getDb(env);
      const [result] = await db
        .insert(eventsTable)
        .values({
          title: body.title,
          description: body.description || null,
          organizerId: body.organizer_id || null,
          venueId: body.venue_id || null,
          date: body.date,
          startTime: body.start_time || null,
          endTime: body.end_time || null,
          price: body.price || null,
          level: body.level || null,
          type: body.type || "social",
          rrule,
          isRecurring,
        })
        .returning({ id: eventsTable.id });

      if (result?.id) {
        return Astro.redirect("/admin/events");
      }
    } catch (e) {
      formError = e instanceof Error ? e.message : String(e);
    }
  }
}
---

<!doctype html>
<html lang="en" data-theme="white-rabbit">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>New Event — Admin — White Rabbit</title>
    <script is:inline>
      const savedTheme = localStorage.getItem("white-rabbit-theme") || "white-rabbit";
      document.documentElement.setAttribute("data-theme", savedTheme);
    </script>
  </head>
  <body>
    <div class="container">
      <header>
        <div class="breadcrumb">
          <a href="/admin">Admin</a>
          <span class="sep">/</span>
          <a href="/admin/events">Events</a>
          <span class="sep">/</span>
          <span>New</span>
        </div>
      </header>

      <h1>New Event</h1>

      {formError && <p class="form-error">{formError}</p>}

      <form method="POST" class="event-form">
        <div class="form-group">
          <label for="title">Title <span class="required">*</span></label>
          <input id="title" type="text" name="title" required />
        </div>

        <div class="form-group">
          <label for="description">Description</label>
          <textarea id="description" name="description" rows="4"></textarea>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="organizer_id">Organizer</label>
            <select id="organizer_id" name="organizer_id">
              <option value="">— None —</option>
              {organizers.map((o) => <option value={o.id}>{o.name}</option>)}
            </select>
          </div>

          <div class="form-group">
            <label for="venue_id">Venue</label>
            <select id="venue_id" name="venue_id">
              <option value="">— None —</option>
              {
                venues.map((v) => (
                  <option value={v.id}>
                    {v.name}{v.city ? ` (${v.city})` : ""}
                  </option>
                ))
              }
            </select>
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="date">Date <span class="required">*</span></label>
            <input id="date" type="date" name="date" required />
          </div>

          <div class="form-group">
            <label for="start_time">Start Time</label>
            <input id="start_time" type="time" name="start_time" />
          </div>

          <div class="form-group">
            <label for="end_time">End Time</label>
            <input id="end_time" type="time" name="end_time" />
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="price">Price</label>
            <input id="price" type="text" name="price" placeholder="e.g. $10, Free" />
          </div>

          <div class="form-group">
            <label for="level">Level</label>
            <input id="level" type="text" name="level" placeholder="e.g. All levels, Intermediate" />
          </div>

          <div class="form-group">
            <label for="type">Type</label>
            <select id="type" name="type">
              <option value="social">Social</option>
              <option value="workshop">Workshop</option>
              <option value="competition">Competition</option>
            </select>
          </div>
        </div>

        <div class="form-group">
          <label>Recurrence</label>
          <div class="radio-group">
            <label class="radio-label">
              <input type="radio" name="recurring" value="once" checked /> One-time
            </label>
            <label class="radio-label">
              <input type="radio" name="recurring" value="weekly" /> Weekly
            </label>
            <label class="radio-label">
              <input type="radio" name="recurring" value="biweekly" /> Bi-weekly
            </label>
            <label class="radio-label">
              <input type="radio" name="recurring" value="monthly" /> Monthly
            </label>
          </div>
        </div>

        <div class="form-actions">
          <a href="/admin/events" class="btn-cancel">Cancel</a>
          <button type="submit" class="btn-submit">Create Event</button>
        </div>
      </form>
    </div>
  </body>
</html>

<style>
  body {
    margin: 0;
    background: var(--bg-primary);
    color: var(--text-primary);
    font-family: var(--font-primary);
    min-height: 100vh;
  }

  .container {
    max-width: 760px;
    margin: 0 auto;
    padding: 40px 32px;
  }

  header {
    margin-bottom: 24px;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.9rem;
  }

  .breadcrumb a {
    color: var(--accent-primary);
    text-decoration: none;
  }

  .sep {
    color: var(--text-muted);
  }

  h1 {
    margin: 0 0 28px;
    font-size: 1.5rem;
    color: var(--accent-primary);
  }

  .event-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex: 1;
  }

  .form-row {
    display: flex;
    gap: 16px;
  }

  @media (max-width: 600px) {
    .form-row {
      flex-direction: column;
    }
  }

  label {
    font-size: 0.85rem;
    color: var(--text-secondary);
  }

  .required {
    color: var(--accent-primary);
  }

  input[type="text"],
  input[type="date"],
  input[type="time"],
  select,
  textarea {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    font-family: var(--font-primary);
    font-size: 0.95rem;
    padding: 10px 12px;
    outline: none;
    width: 100%;
    box-sizing: border-box;
  }

  input:focus,
  select:focus,
  textarea:focus {
    border-color: var(--accent-primary);
  }

  textarea {
    resize: vertical;
  }

  select option {
    background: var(--bg-secondary);
  }

  .radio-group {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
  }

  .radio-label {
    display: flex;
    align-items: center;
    gap: 6px;
    cursor: pointer;
    font-size: 0.9rem;
    color: var(--text-primary);
  }

  .form-actions {
    display: flex;
    gap: 12px;
    padding-top: 8px;
  }

  .btn-cancel {
    padding: 10px 20px;
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
    text-decoration: none;
    font-family: var(--font-primary);
    font-size: 0.95rem;
    transition: border-color 0.2s;
  }

  .btn-cancel:hover {
    border-color: var(--accent-primary);
    color: var(--text-primary);
  }

  .btn-submit {
    padding: 10px 28px;
    background: transparent;
    border: 2px solid var(--accent-primary);
    color: var(--text-primary);
    font-family: var(--font-primary);
    font-size: 0.95rem;
    cursor: pointer;
    transition: all 0.2s;
  }

  .btn-submit:hover {
    background: var(--accent-primary);
    color: var(--bg-primary);
  }

  .form-error {
    color: #ff4444;
    border: 1px solid #ff4444;
    padding: 12px 16px;
    margin-bottom: 8px;
  }
</style>
