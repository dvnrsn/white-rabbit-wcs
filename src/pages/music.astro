---
import Layout from "../layouts/Layout.astro";
import { generateOrganizationSchema } from "../lib/schema";
import { getCollection, getEntry } from "astro:content";

const schema = generateOrganizationSchema();

const DUMMY_DJS = [
  { handle: "DJ Nyx", realName: "Nicole Y.", bio: "Nyx brings a dark, hypnotic energy to the floor — deep house grooves layered over neo-soul and trip-hop. Known for late-night sets that keep dancers moving long past closing.", style: ["Neo Soul", "Deep House", "Trip-Hop"], resident: true },
  { handle: "DJ Cipher", realName: "Chris M.", bio: "Cipher's sets are a master class in musicality — he reads the room and builds narratives across the night. Expect modern RnB, left-field pop, and the occasional surprise throwback.", style: ["Modern RnB", "Alternative Pop", "Funk"], resident: true },
  { handle: "DJ Flux", realName: "Felicia O.", bio: "Flux specializes in the 120–128 BPM sweet spot that WCS dancers live in. Her library spans indie electronic to neo-funk, always with impeccable phrasing.", style: ["Indie Electronic", "Neo-Funk", "Downtempo"], resident: false },
  { handle: "DJ Static", realName: "Sam T.", bio: "The anchor of early evening sets. Static builds the room up slowly — smooth vocals, laid-back grooves, and just enough tension to pull dancers onto the floor.", style: ["Soul", "Smooth RnB", "Chill Hop"], resident: false },
];

const [djEntries, playlistEntries, pageEntry] = await Promise.all([
  getCollection("djs"),
  getCollection("playlists"),
  getEntry("pages", "music"),
]);

const djs = djEntries.length > 0 ? djEntries.map((e) => e.data) : DUMMY_DJS;

const copy = {
  approachText: pageEntry?.data.approachText ?? "Music is the reason we're all here. West Coast Swing was built on the idea that great dancing follows great music — not the other way around. We take that seriously.\n\nEvery White Rabbit event is curated, not shuffled. Our DJs don't just play songs; they build sets with intention, reading the room and shaping the energy of the night from the first note to the last.",
  philosophyText: pageEntry?.data.philosophyText ?? "We play music that moves people — literally. That means staying contemporary without chasing trends, honoring the roots of WCS while staying open to where music is going. Neo-soul, indie electronic, modern RnB, left-field pop. Anything that hits the right pocket.\n\nThe tempo sweet spot we live in: 110–128 BPM. Wide enough for expression, tight enough to dance.",
  manifestoLine: pageEntry?.data.manifestoLine ?? "IF IT GROOVES, IT QUALIFIES.",
  manifestoSubline: pageEntry?.data.manifestoSubline ?? "Genre is a suggestion. Phrasing is law.",
  playlistsIntro: pageEntry?.data.playlistsIntro ?? "Curated sets for home listening, practice, and late-night winding down. Full streaming links coming soon.",
};

const playlists = playlistEntries.map((e) => e.data);

function toSpotifyEmbed(url: string): string {
  return url.replace("open.spotify.com/", "open.spotify.com/embed/").split("?")[0];
}
---

<Layout
  title="Music - The White Rabbit Society"
  description="Discover the sounds of White Rabbit WCS. Meet our DJs, explore playlists, and learn about our approach to music and dance."
  schema={schema}
>
  <main class="music-page">
    <div class="container">
      <header class="page-header">
        <div class="header-glyph">//</div>
        <h1 class="page-title gradient-text">The Sound</h1>
        <p class="page-subtitle">Music · Philosophy · DJs</p>
      </header>

      <section class="philosophy-section">
        <div class="philosophy-grid">
          <div class="philosophy-block">
            <h2 class="section-title">> Our Approach</h2>
            {copy.approachText.split("\n\n").map((p) => <p>{p}</p>)}
          </div>
          <div class="philosophy-block">
            <h2 class="section-title">> The Philosophy</h2>
            {copy.philosophyText.split("\n\n").map((p) => <p>{p}</p>)}
          </div>
        </div>

        <div class="manifesto-block">
          <div class="manifesto-line">{copy.manifestoLine}</div>
          <div class="manifesto-line secondary">{copy.manifestoSubline}</div>
        </div>
      </section>

      <section class="dj-section">
        <h2 class="section-title">> The DJs</h2>
        <p class="section-intro">
          The people behind the music. Our resident and guest DJs define the
          White Rabbit sound.
        </p>
        <div class="dj-grid">
          {
            djs.map((dj) => (
              <div class={`card dj-card ${dj.resident ? "resident" : ""}`}>
                {dj.photo && (
                  <div class="dj-photo">
                    <img src={dj.photo} alt={dj.handle ?? dj.name} loading="lazy" decoding="async" />
                  </div>
                )}
                <div class="dj-header">
                  <div>
                    <div class="dj-handle">{dj.handle}</div>
                    <div class="dj-real">{dj.realName}</div>
                  </div>
                  {dj.resident && (
                    <span class="resident-badge">Resident</span>
                  )}
                </div>
                <p class="dj-bio">{dj.bio}</p>
                <div class="dj-tags">
                  {dj.style.map((s) => (
                    <span class="tag">{s}</span>
                  ))}
                </div>
                {(dj.instagram || dj.spotify || dj.mixcloud || dj.soundcloud) && (
                  <div class="dj-links">
                    {dj.instagram && (
                      <a href={`https://instagram.com/${dj.instagram.replace(/^@/, "")}`} class="dj-link" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                          <circle cx="12" cy="12" r="4"/>
                          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
                        </svg>
                      </a>
                    )}
                    {dj.spotify && (
                      <a href={dj.spotify} class="dj-link" target="_blank" rel="noopener noreferrer" aria-label="Spotify">
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                          <path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm4.586 14.424c-.18.295-.563.387-.857.207-2.35-1.434-5.305-1.76-8.786-.963-.335.077-.67-.133-.746-.469-.077-.336.132-.67.469-.746 3.809-.87 7.076-.496 9.713 1.115.293.18.386.563.207.856zm1.223-2.722c-.226.367-.706.482-1.072.257-2.687-1.652-6.785-2.131-9.965-1.166-.413.127-.848-.106-.973-.517-.125-.413.108-.848.518-.973 3.632-1.102 8.147-.568 11.234 1.328.366.226.48.707.258 1.072zm.105-2.835C14.692 8.95 9.375 8.775 6.297 9.71c-.493.15-1.016-.129-1.166-.623-.148-.495.13-1.016.624-1.166 3.532-1.073 9.404-.866 13.115 1.337.445.264.59.838.327 1.282-.264.443-.838.59-1.283.326z"/>
                        </svg>
                      </a>
                    )}
                    {dj.mixcloud && (
                      <a href={dj.mixcloud} class="dj-link" target="_blank" rel="noopener noreferrer">
                        Mixcloud
                      </a>
                    )}
                    {dj.soundcloud && (
                      <a href={dj.soundcloud} class="dj-link" target="_blank" rel="noopener noreferrer">
                        SoundCloud
                      </a>
                    )}
                  </div>
                )}
              </div>
            ))
          }
        </div>
      </section>

      <section class="playlist-section">
        <h2 class="section-title">> Playlists</h2>
        <p class="section-intro">
          {copy.playlistsIntro}
        </p>
        {playlists.length === 0 ? (
          <p class="section-intro">Playlists coming soon.</p>
        ) : (
          <div class="playlist-list">
            {playlists.map((playlist) => (
              <div class="playlist-card">
                <div class="playlist-header">
                  <span class="playlist-title">{playlist.title}</span>
                  {playlist.mood && <span class="playlist-mood">{playlist.mood}</span>}
                </div>
                <p class="playlist-desc">{playlist.description ?? ""}</p>
                <iframe
                  src={toSpotifyEmbed(playlist.spotifyUrl)}
                  width="100%"
                  height="352"
                  frameborder="0"
                  allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
                  loading="lazy"
                ></iframe>
              </div>
            ))}
          </div>
        )}
      </section>
    </div>
  </main>
</Layout>

<style>
  .music-page {
    padding: 3rem 0;
    min-height: calc(100vh - 80px);
  }

  .page-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .header-glyph {
    font-family: var(--font-primary);
    font-size: 2rem;
    color: var(--accent-primary);
    opacity: 0.5;
    margin-bottom: 8px;
    letter-spacing: 0.3em;
  }

  .page-title {
    font-size: clamp(2.5rem, 8vw, 4rem);
    margin-bottom: 0.5rem;
    letter-spacing: 0.1em;
  }

  .page-subtitle {
    font-size: 1rem;
    color: var(--text-secondary);
    letter-spacing: 0.3em;
    text-transform: uppercase;
  }

  .section-title {
    font-size: 1.8rem;
    color: var(--accent-primary);
    margin-bottom: 1rem;
    font-family: var(--font-primary);
  }

  .section-intro {
    color: var(--text-secondary);
    font-size: 1.05rem;
    margin-bottom: 1.5rem;
    line-height: 1.7;
  }

  /* Philosophy */
  .philosophy-section {
    margin-bottom: 5rem;
  }

  .philosophy-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    margin-bottom: 3rem;
  }

  .philosophy-block p {
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: 1rem;
    font-size: 1.05rem;
  }

  .manifesto-block {
    border-top: 1px solid var(--border-color);
    border-bottom: 1px solid var(--border-color);
    padding: 32px 0;
    text-align: center;
  }

  .manifesto-line {
    font-family: var(--font-primary);
    font-size: clamp(1.2rem, 4vw, 2rem);
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--accent-primary);
    line-height: 1.4;
  }

  .manifesto-line.secondary {
    font-size: clamp(0.9rem, 2.5vw, 1.2rem);
    color: var(--text-secondary);
    font-weight: 400;
    margin-top: 8px;
    letter-spacing: 0.1em;
  }

  /* DJs */
  .dj-section {
    margin-bottom: 5rem;
  }

  .dj-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 16px;
  }

  .dj-card {
    display: flex;
    flex-direction: column;
  }

  .dj-card.resident {
    border-color: var(--accent-primary);
  }

.dj-photo {
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    margin-bottom: 16px;
  }

  .dj-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .dj-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 12px;
  }

  .dj-handle {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text-primary);
    font-family: var(--font-primary);
  }

  .resident-badge {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent-primary);
    border: 1px solid var(--accent-primary);
    padding: 2px 8px;
    white-space: nowrap;
  }

  .dj-real {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-top: 2px;
  }

.dj-bio {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 12px;
  }

  .dj-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .tag {
    font-size: 0.75rem;
    padding: 3px 8px;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
  }

  /* Playlists */
  .playlist-section {
    margin-bottom: 4rem;
  }

  .playlist-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    grid-template-rows: repeat(3, auto);
    column-gap: 40px;
    row-gap: 48px;
  }

  .playlist-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 8px;
  }

  .playlist-title {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--text-primary);
    font-family: var(--font-primary);
  }

  .playlist-mood {
    font-size: 0.75rem;
    color: var(--accent-primary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    white-space: nowrap;
  }

  .playlist-desc {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  .playlist-card {
    display: grid;
    grid-template-rows: subgrid;
    grid-row: span 3;
    row-gap: 8px;
  }

  .playlist-card iframe {
    border: none;
    border-radius: 0;
    display: block;
  }

  .dj-links {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: auto;
    padding-top: 12px;
  }

  .dj-link {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-secondary);
    text-decoration: none;
    line-height: 1;
    transition: none;
  }

  .dj-link svg {
    width: 28px;
    height: 28px;
  }

  .dj-link:hover {
    color: var(--accent-primary);
  }

  @media (max-width: 768px) {
    .dj-link svg {
      width: 40px;
      height: 40px;
    }
  }

  @media (max-width: 768px) {
    .music-page {
      padding: 2rem 0;
    }

    .page-header {
      margin-bottom: 3rem;
    }

    .philosophy-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .section-title {
      font-size: 1.4rem;
    }

    .playlist-list {
      grid-template-columns: 1fr;
      column-gap: 0;
      row-gap: 40px;
    }

    .playlist-header {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
