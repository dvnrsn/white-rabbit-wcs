---
import Layout from "../layouts/Layout.astro";
import RecentPosts from "../components/RecentPosts.astro";
import { generateOrganizationSchema } from "../lib/schema";

const schema = generateOrganizationSchema();
---

<Layout
  title="White Rabbit - Arizona West Coast Swing"
  description="Follow the white rabbit into Arizona's West Coast Swing scene. Find events, workshops, socials across Phoenix, Tucson, Prescott and beyond. Connect with the Arizona WCS dance community."
  schema={schema}
>
  <main>
    <section class="hero">
      <div class="container">
        <img src="/logo.webp" alt="White Rabbit Society" class="hero-logo" />
        <h1 class="title gradient-text">THE WHITE RABBIT SOCIETY</h1>
        <p class="tagline">Arizona WCS</p>
        <div class="typed-text" id="typed-text"></div>

        <div class="typed-text" id="typed-text-2"></div>

        <div class="cta-buttons">
          <a href="/events" class="btn">View Events</a>
          <a href="/about" class="btn">Learn More</a>
        </div>
      </div>
    </section>

    <section class="features">
      <div class="container">
        <div class="features-grid">
          <a href="/events" class="card feature">
            <h3>> Events</h3>
            <p>
              Find West Coast Swing dances, workshops, and socials happening
              across Arizona - Phoenix, Tucson, Prescott and beyond.
            </p>
          </a>

          <a href="/community" class="card feature">
            <h3>> Community</h3>
            <p>
              Connect with dancers, teachers, venues, and other resources in
              the Arizona WCS scene.
            </p>
          </a>

          <a href="/music" class="card feature">
            <h3>> Music</h3>
            <p>
              Discover new music, read about our approach and philosophy, and
              get to know our DJs.
            </p>
          </a>

          <a href="/shop" class="card feature">
            <h3>> Shop</h3>
            <p>Cop the merch, support White Rabbit.</p>
          </a>
        </div>
      </div>
    </section>
    <RecentPosts />
  </main>
</Layout>

<style>
  .hero {
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .hero-logo {
    width: 160px;
    height: 160px;
    border-radius: 50%;
    margin-bottom: 24px;
    animation: fadeInGlow 1s ease-out;
  }

  .title {
    font-size: clamp(2rem, 7vw, 4.5rem);
    margin-bottom: 1rem;
    letter-spacing: 0.15em;
    font-weight: 700;
    animation: fadeInGlow 1s ease-out;
  }

  @keyframes fadeInGlow {
    from {
      opacity: 0;
      filter: drop-shadow(0 0 0px var(--accent-primary));
    }
    to {
      opacity: 1;
      filter: drop-shadow(0 0 20px var(--accent-primary));
    }
  }

  .tagline {
    font-size: 1.2rem;
    color: var(--accent-primary);
    margin-bottom: 3rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    animation: fadeIn 1s ease-out 0.3s both;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .typed-text {
    min-height: 100px;
    max-width: 800px;
    margin: 0 auto 3rem;
    font-size: 1.2rem;
    line-height: 1.8;
    color: var(--text-secondary);
    animation: fadeIn 1s ease-out 0.6s both;
  }

  #typed-text-2 {
    min-height: unset;
    margin-bottom: 3.5rem;
  }

  .cta-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    animation: fadeIn 1s ease-out 0.9s both;
  }

  .btn-secondary {
    opacity: 0.7;
    font-size: 0.9rem;
  }

  .features {
    padding: 4rem 0;
    background: var(--bg-secondary);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    margin-top: 2rem;
  }

  @media (max-width: 1024px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .feature {
    text-align: center;
    text-decoration: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .feature:hover {
    border-color: var(--accent-primary);
    box-shadow: var(--shadow-glow);
  }

  .feature h3 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    color: var(--accent-primary);
  }

  .feature p {
    color: var(--text-secondary);
    line-height: 1.8;
  }

  /* Floating particles effect */
  .hero::before {
    content: "";
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(
      circle,
      var(--accent-primary) 1px,
      transparent 1px
    );
    background-size: 50px 50px;
    opacity: 0.05;
    animation: float 20s linear infinite;
    pointer-events: none;
  }

  @keyframes float {
    0% {
      transform: translate(0, 0);
    }
    100% {
      transform: translate(50px, 50px);
    }
  }

  @media (max-width: 768px) {
    .features-grid {
      grid-template-columns: 1fr;
    }

    .hero {
      min-height: 70vh;
    }

    .title {
      letter-spacing: 0.1em;
    }

    .tagline {
      letter-spacing: 0.2em;
    }

    .typed-text {
      font-size: 1rem;
      padding: 0 1rem;
    }

    #typed-text-2 {
      margin-bottom: 2.5rem;
    }

    .cta-buttons {
      flex-direction: column;
      align-items: stretch;
      padding: 0 2rem;
    }
  }
</style>

<script>
  // Typing effect
  const text =
    "Wake up, Neo... The dance floor is calling. Phoenix's underground West Coast Swing community awaits. Find events, connect with dancers, and discover your flow.";
  const text2 = "Follow the white rabbit.";
  const typedTextElement = document.getElementById("typed-text");
  const typedTextElement2 = document.getElementById("typed-text-2");
  let index = 0;

  function typeText2() {
    if (typedTextElement2 && index < text2.length) {
      const currentText = text2.substring(0, index + 1);
      typedTextElement2.innerHTML = currentText + '<span class="cursor"></span>';
      index++;
      setTimeout(typeText2, 50);
    }
  }

  function typeText() {
    if (typedTextElement && index < text.length) {
      const currentText = text.substring(0, index + 1);
      typedTextElement.innerHTML = currentText + '<span class="cursor"></span>';
      index++;
      setTimeout(typeText, 50);
    } else if (typedTextElement) {
      typedTextElement.innerHTML = text;
      index = 0;
      setTimeout(typeText2, 400);
    }
  }

  // Start typing after a short delay
  setTimeout(typeText, 1200);
</script>
